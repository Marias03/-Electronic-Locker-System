generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Casillero {
  id        Int      @id @default(autoincrement())
  numero    Int      @unique
  tamanio   String
  ocupado   Boolean  @default(false)
  usuario   String?
  email     String?
  pin       String?
  createdAt DateTime @default(now())
}
